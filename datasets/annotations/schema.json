{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KYC Document OCR Annotation Schema",
  "description": "Annotation format for Sri Lankan identity document OCR training data. Compatible with LabelStudio and exportable to PaddleOCR detection/recognition format.",
  "type": "object",
  "required": ["id", "document_type", "ground_truth", "image_size"],
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique annotation ID within the dataset split"
    },
    "document_type": {
      "type": "string",
      "enum": ["nic", "passport", "driving_license"],
      "description": "Type of identity document"
    },
    "format": {
      "type": "string",
      "enum": ["old", "new", "td3", "standard"],
      "description": "Document sub-format (e.g. old/new NIC, TD3 passport)"
    },
    "source": {
      "type": "string",
      "enum": ["synthetic", "real_anonymised"],
      "default": "synthetic",
      "description": "Data provenance — real documents must be anonymised before annotation"
    },
    "augmented": {
      "type": "boolean",
      "default": false,
      "description": "True if this image has been augmented from a source image"
    },
    "source_image": {
      "type": "string",
      "description": "Filename of the original image (augmented images only)"
    },
    "ground_truth": {
      "type": "object",
      "description": "Field-level ground truth values",
      "properties": {
        "document_number": {
          "type": "string",
          "description": "NIC number, passport number, or driving license number"
        },
        "full_name": {
          "type": "string",
          "description": "Full name as printed on the document"
        },
        "surname": {
          "type": "string",
          "description": "Surname / family name (passports only)"
        },
        "given_names": {
          "type": "string",
          "description": "Given names (passports only)"
        },
        "dob": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Date of birth in ISO 8601 (YYYY-MM-DD)"
        },
        "sex": {
          "type": "string",
          "enum": ["M", "F"],
          "description": "Sex as printed on document"
        },
        "nationality": {
          "type": "string",
          "description": "3-letter ISO 3166-1 alpha-3 code (e.g. LKA)"
        },
        "expiry_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Document expiry date in ISO 8601"
        },
        "issue_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Document issue date in ISO 8601 (driving licenses, some NICs)"
        },
        "address": {
          "type": "string",
          "description": "Residential address (driving licenses)"
        },
        "vehicle_categories": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Authorised vehicle categories (driving licenses)"
        },
        "mrz_line1": {
          "type": "string",
          "maxLength": 44,
          "description": "MRZ line 1 — 44-character TD3 string (passports)"
        },
        "mrz_line2": {
          "type": "string",
          "maxLength": 44,
          "description": "MRZ line 2 — 44-character TD3 string (passports)"
        }
      }
    },
    "text_regions": {
      "type": "array",
      "description": "Labelled text regions for detection model training",
      "items": {
        "type": "object",
        "required": ["transcription", "points"],
        "properties": {
          "transcription": {
            "type": "string",
            "description": "Exact text content of this region"
          },
          "field_label": {
            "type": "string",
            "description": "Semantic field (document_number, full_name, dob, etc.) or 'label' for static text"
          },
          "points": {
            "type": "array",
            "description": "Polygon corners [x, y] clockwise from top-left",
            "items": {
              "type": "array",
              "items": {"type": "number"},
              "minItems": 2,
              "maxItems": 2
            },
            "minItems": 4
          },
          "language": {
            "type": "string",
            "enum": ["en", "si", "ta"],
            "default": "en",
            "description": "Text language: en=English, si=Sinhala, ta=Tamil"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Annotation confidence (1.0 for ground truth, <1.0 for OCR-assisted)"
          }
        }
      }
    },
    "bboxes": {
      "type": "object",
      "description": "Axis-aligned bounding boxes keyed by field name [x1, y1, x2, y2]",
      "additionalProperties": {
        "type": "array",
        "items": {"type": "number"},
        "minItems": 4,
        "maxItems": 4
      }
    },
    "document_corners": {
      "type": "array",
      "description": "Four corners of the physical document in image coordinates (for perspective correction training)",
      "items": {
        "type": "array",
        "items": {"type": "number"},
        "minItems": 2,
        "maxItems": 2
      },
      "minItems": 4,
      "maxItems": 4
    },
    "image_size": {
      "type": "array",
      "items": {"type": "integer"},
      "minItems": 2,
      "maxItems": 2,
      "description": "[width, height] of the image in pixels"
    },
    "quality": {
      "type": "object",
      "description": "Image quality flags (set during annotation review)",
      "properties": {
        "blurry": {"type": "boolean"},
        "glare": {"type": "boolean"},
        "low_light": {"type": "boolean"},
        "perspective_distorted": {"type": "boolean"},
        "partial_occlusion": {"type": "boolean"}
      }
    }
  }
}
